{
  "name": "flowqueue-backend",
  "version": "1.0.0",
  "description": "FlowQueue Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
